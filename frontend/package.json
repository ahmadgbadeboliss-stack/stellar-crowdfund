{
  "name": "stellar-crowdfund-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Mobile-responsive React dApp for the Stellar crowdfunding contracts.",
  "scripts": {
    "dev": "vite",
